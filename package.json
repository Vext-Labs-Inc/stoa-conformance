{
  "name": "@stoa/conformance",
  "version": "0.1.0",
  "description": "Stoa conformance test suite — automatable L0-L4 tests, JSON report emitter, CLI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "stoa-conformance": "./dist/bin/stoa-conformance.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vext-Labs-Inc/stoa-conformance.git"
  },
  "keywords": ["stoa", "conformance", "testing", "L0", "L1", "L2", "L3", "L4", "agent"]
}
